// Основные цвета Wildberries
$wb-purple-primary: #6F2DBD; // Логотип, кнопки "Купить", важные акценты
$wb-purple-secondary: #8A4FFF; // Фон верхнего меню, подложки, иконки
$wb-white: #FFFFFF; // Основной фон сайта, текст на тёмном фоне
$wb-black-text: #212121; // Основной цвет текста, заголовки
$wb-light-gray: #F4F4F4; // Фон карточек товаров, границы, разделители
$wb-alert-red: #FF3B30; // Ошибки, уведомления, предупреждения

body {
  background-color: $wb-white; // фон страницы — белый
  color: $wb-black-text; // цвет текста — тёмно-серый
}
